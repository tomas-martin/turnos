PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/turnos?schema=public"

JWT_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Nodemailer SMTP Configuration
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="your-smtp-username"
EMAIL_PASS="your-smtp-password"
EMAIL_FROM="no-reply@turnos-saas.com"

# Cloudinary (Optional, for image uploads. If not set, local storage will be used)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Ollama local AI server
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b"
