PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/turnos?schema=public"

JWT_SECRET="dev-access-secret-12345-extremely-long-string-for-security"
JWT_REFRESH_SECRET="dev-refresh-secret-12345-extremely-long-string-for-security"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Nodemailer SMTP Configuration (we can use Mailtrap or Ethereal for testing)
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="your-smtp-username"
EMAIL_PASS="your-smtp-password"
EMAIL_FROM="no-reply@turnos-saas.com"

# Cloudinary (Optional, fallback to local uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Ollama local AI server
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b"
